# Server Configuration
SERVER_NAME="Production MCP Server"
SERVER_VERSION="1.0.0"

# Logging Configuration
LOG_LEVEL="info"

# Security Configuration
# Set this to a strong secret to enable global API key verification
MCP_API_KEY="my-secret-key"

# System Connections (Leave empty to use Mock Clients)
PROMETHEUS_ADDR=""
DB_DRIVER="postgres"
DB_DSN=""

ELASTICSEARCH_URL="http://localhost:9200"
